{
  "name": "business-ventures",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "build:with-budget": "vite build && node scripts/check-bundle-budget.mjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"server.ts\" \"vite.config.ts\" --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "lint:rules": "eslint firestore.rules --max-warnings=0",
    "validate:firestore-rules": "npm run lint:rules",
    "check:bundle-budget": "node scripts/check-bundle-budget.mjs",
    "check:file-guardrails": "node scripts/check-file-guardrails.mjs",
    "format": "prettier --write \"{src,.github/workflows}/**/*.{ts,tsx,js,mjs,yml,yaml}\" \"server.ts\" \"vite.config.ts\" \"*.json\"",
    "format:check": "prettier --check \"{src,.github/workflows}/**/*.{ts,tsx,js,mjs,yml,yaml}\" \"server.ts\" \"vite.config.ts\" \"*.json\"",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs,js,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,tsx,mjs,js}": [
      "eslint --max-warnings=0"
    ]
  },
  "dependencies": {
    "@firebase/eslint-plugin-security-rules": "^0.0.1",
    "@google/genai": "^1.29.0",
    "@stripe/stripe-js": "^9.1.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.8.0",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "stripe": "^22.0.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.59.0",
    "vite": "^6.4.2",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "protobufjs": "^7.5.5",
    "fast-xml-parser": "^5.7.1",
    "@tootallnate/once": "^3.0.1"
  }
}
