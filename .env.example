# .env.example
GEMINI_API_KEY=
VITE_STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Firebase Admin Audit Compliance
# Set this to the absolute path of your service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_PROJECT_ID=

# Comma-separated list of approved frontend origins for checkout and CORS.
# Example: FRONTEND_ORIGINS=http://localhost:5173,https://app.example.com
FRONTEND_ORIGINS=

# Optional default origin used when Origin/Referer headers are unavailable.
FRONTEND_DEFAULT_ORIGIN=http://localhost:5173
